{
  "expo": {
    "name": "Prism",
    "slug": "prism",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "prism",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#05070f",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#05070f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prismhabits.app"
    },
    "android": {
      "package": "com.prismhabits.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05070f"
      }
    }
  }
}
