{
  "expo": {
    "name": "MoodScape",
    "slug": "moodscape",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "moodscape",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#070b1a",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070b1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moodscape.app"
    },
    "android": {
      "package": "com.moodscape.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070b1a"
      }
    }
  }
}
